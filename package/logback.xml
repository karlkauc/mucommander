<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%.15thread] %-5level %X{jobId:-main} %logger{36}:%line - %msg%n</pattern>
        </encoder>
    </appender>
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${MUCOMMANDER_USER_PREFERENCES}/logs/mucommander.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- rollover daily -->
            <fileNamePattern>${MUCOMMANDER_USER_PREFERENCES}/logs/mucommander-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- each file should be at most 10MB, keep 7 days worth of history, but at most 200MB -->
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%.15thread] %-5level %X{jobId:-main} %logger{36}:%line - %msg%n</pattern>
        </encoder>
    </appender>
    <!--
        Async wrapper around FILE — disk I/O happens on a dedicated thread so
        a slow log write can't block job/UI threads. queueSize 512 holds about
        1-2 seconds worth of logs at peak; on overflow Logback drops TRACE/DEBUG/INFO
        but always keeps WARN/ERROR (default neverBlock=false, discardingThreshold=20%).
    -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <includeCallerData>true</includeCallerData>
        <appender-ref ref="FILE" />
    </appender>
    <root level="all">
        <appender-ref ref="ASYNC_FILE" />
        <appender-ref ref="STDOUT" />
    </root>
</configuration>
