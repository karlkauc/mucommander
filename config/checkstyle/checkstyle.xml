<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    muCommander Checkstyle base configuration.

    Initial intent (Phase 0.2 of the modernization plan): catch unambiguous
    quality issues without bikeshedding the existing formatting style. Whitespace
    and brace-position checks are intentionally absent — those are owned by the
    Eclipse formatter (mucommander-code-format.xml).

    Modules with ignoreFailures=false (currently mucommander-commons-*) treat
    violations as errors; the rest emit warnings only. Tighten the ruleset
    incrementally as the codebase is cleaned up.
-->
<module name="Checker">
    <property name="severity" value="warning"/>
    <property name="charset" value="UTF-8"/>
    <property name="fileExtensions" value="java"/>

    <!-- Files end with a single newline. -->
    <module name="NewlineAtEndOfFile">
        <property name="lineSeparator" value="lf_cr_crlf"/>
    </module>

    <!-- Catch leftover \t in files that should be spaces (or vice versa).
         Disabled initially — too noisy on legacy code.
    <module name="FileTabCharacter"/>
    -->

    <module name="TreeWalker">
        <!-- Imports: cheap wins, low false-positive rate. -->
        <module name="AvoidStarImport"/>
        <module name="RedundantImport"/>
        <module name="UnusedImports">
            <property name="processJavadoc" value="true"/>
        </module>

        <!-- Naming: standard Java conventions. -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-zA-Z_][a-zA-Z0-9_]*)*$"/>
        </module>
        <module name="TypeName"/>
        <module name="MethodName"/>
        <module name="ConstantName"/>
        <module name="LocalVariableName"/>
        <module name="LocalFinalVariableName"/>
        <module name="MemberName"/>
        <module name="ParameterName"/>
        <module name="StaticVariableName"/>

        <!-- Bug-prone patterns. -->
        <module name="EmptyBlock">
            <property name="option" value="text"/>
            <property name="tokens"
                      value="LITERAL_DO,LITERAL_ELSE,LITERAL_FINALLY,LITERAL_IF,
                             LITERAL_FOR,LITERAL_TRY,LITERAL_WHILE,STATIC_INIT"/>
        </module>
        <module name="EmptyStatement"/>
        <module name="EqualsHashCode"/>
        <module name="MissingSwitchDefault"/>
        <module name="FallThrough"/>
        <module name="StringLiteralEquality"/>
        <module name="SimplifyBooleanExpression"/>
        <module name="SimplifyBooleanReturn"/>
        <module name="DefaultComesLast"/>

        <!-- Modifiers. -->
        <module name="ModifierOrder"/>
        <module name="RedundantModifier"/>

        <!-- Misc. -->
        <module name="UpperEll"/>
        <module name="ArrayTypeStyle"/>
        <module name="OuterTypeFilename"/>
    </module>
</module>
